# PostgreSQL credentials
POSTGRES_DB=sales_management
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Spring profile (prod / dev)
SPRING_PROFILE=prod
JPA_DDL_AUTO=validate

# JWT secret — Base64-encoded string of at least 256 bits
JWT_SECRET=c2VjcmV0LWp3dC1rZXktZm9yLXNhbGVzLW1hbmFnZW1lbnQtc3lzdGVtLWNoYW5nZW1l

# Optional: override default 24h token TTL (milliseconds)
# JWT_EXPIRATION_MS=86400000

# Default admin bootstrap (recommended false in release)
APP_DEFAULT_ADMIN_ENABLED=false
# APP_DEFAULT_ADMIN_USERNAME=admin1
# APP_DEFAULT_ADMIN_PASSWORD=change-me

# SMTP defaults for local Docker (MailHog)
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@salesapp.com
APP_MAIL_ENABLED=true
MAIL_SMTP_AUTH=false
MAIL_SMTP_STARTTLS_ENABLE=false

# For production SMTP, override with real values:
# MAIL_HOST=smtp.example.com
# MAIL_PORT=587
# MAIL_USERNAME=your-smtp-user
# MAIL_PASSWORD=your-smtp-password
# MAIL_SMTP_AUTH=true
# MAIL_SMTP_STARTTLS_ENABLE=true
